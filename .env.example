# ==============================================================================
# INVENTORY MANAGEMENT SYSTEM - ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to '.env' and adjust the secrets for your target deployment environment.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. APPLICATION KEYS & URLS
# ------------------------------------------------------------------------------
# GEMINI_API_KEY: Required for Gemini AI operations.
# Configure this via secrets panel if using public platform hosting.
GEMINI_API_KEY="your_secure_gemini_api_key_goes_here"

# APP_URL: The public service hosting endpoint (e.g. your cloud run deploy URL)
APP_URL="http://localhost:3000"

# ------------------------------------------------------------------------------
# 2. PORT CONFIGURATIONS (DOCKER-COMPOSE)
# ------------------------------------------------------------------------------
# Port serving the React single-page frontend application
FRONTEND_PORT=3000

# Port serving the FastAPI backend application
BACKEND_PORT=8000

# Exposed port for the internal PostgreSQL database (if accessing externally)
POSTGRES_EXTERNAL_PORT=5432

# ------------------------------------------------------------------------------
# 3. DATABASE CREDENTIALS & VALUES
# ------------------------------------------------------------------------------
# Connection details used by both the PostgreSQL container and the API layer
POSTGRES_SERVER=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres_production_user
POSTGRES_PASSWORD=your_highly_secure_db_password_123!
POSTGRES_DB=inventory_db_production
VITE_API_URL=https://your-backend-domain.com
